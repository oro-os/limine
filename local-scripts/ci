#!/usr/bin/env bash

set -xeuo pipefail
cargo kernel-x86_64 --profile dev
cargo kernel-x86_64 --profile release
cargo limine-x86_64 --profile dev
cargo limine-x86_64 --profile release
cargo kernel-aarch64 --profile dev
cargo kernel-aarch64 --profile release
cargo limine-aarch64 --profile dev
cargo limine-aarch64 --profile release
cargo oro-clippy-common
cargo oro-clippy-x86_64
cargo oro-clippy-aarch64
env RUSTFLAGS="-D warnings" cargo oro-doc-x86_64
env RUSTFLAGS="-D warnings" cargo oro-doc-aarch64
cargo fmt --all -- --check
